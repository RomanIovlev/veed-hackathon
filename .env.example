# Environment Variables for Netlify Deployment

# FAL AI API Key for TTS/Video Generation
FAL_KEY=your_fal_api_key_here

# VEED API Key for Video Generation (optional)
VEED_API_KEY=your_veed_api_key_here

# PostgreSQL Database URL (use cloud database service)
# Example for Neon, Supabase, or Railway:
DATABASE_URL=postgresql://username:password@host:port/database
# Alternative format:
POSTGRES_URL=postgresql://username:password@host:port/database

# Node Environment
NODE_ENV=production